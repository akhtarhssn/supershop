<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Your Email</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #f5f5f7;
      font-family:
        -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial,
        sans-serif;
    "
  >
    <table
      role="presentation"
      border="0"
      cellpadding="0"
      cellspacing="0"
      width="100%"
      style="background-color: #f5f5f7; padding: 40px 10px"
    >
      <tr>
        <td align="center">
          <!-- Main Container -->
          <table
            role="presentation"
            border="0"
            cellpadding="0"
            cellspacing="0"
            width="100%"
            style="
              max-width: 480px;
              background-color: #ffffff;
              border-radius: 18px;
              overflow: hidden;
              box-shadow: 0 4px 30px rgba(0, 0, 0, 0.08);
            "
          >
            <!-- Logo / App Name Area -->
            <tr>
              <td style="padding: 48px 32px 24px 32px; text-align: center">
                <div
                  style="
                    font-size: 32px;
                    font-weight: 600;
                    color: #000000;
                    letter-spacing: -0.5px;
                  "
                >
                  SuperShop
                </div>
              </td>
            </tr>

            <!-- Main Content -->
            <tr>
              <td style="padding: 0 32px 32px 32px">
                <h1
                  style="
                    margin: 0;
                    font-size: 28px;
                    font-weight: 600;
                    color: #1d1d1f;
                    line-height: 1.3;
                    text-align: center;
                    letter-spacing: -0.4px;
                  "
                >
                  Verify your email address
                </h1>

                <!-- Personalized Greeting -->
                <p
                  style="
                    margin: 28px 0 8px 0;
                    font-size: 17px;
                    color: #1d1d1f;
                    line-height: 1.47;
                    text-align: center;
                  "
                >
                  Hi <%= userName || 'there' %>,
                </p>

                <p
                  style="
                    margin: 0 0 32px 0;
                    font-size: 17px;
                    color: #1d1d1f;
                    line-height: 1.47;
                    text-align: center;
                  "
                >
                  Welcome to our platform! Please verify your email address to unlock full access to your dashboard.
                </p>

                <!-- Apple-style Button -->
                <table
                  role="presentation"
                  border="0"
                  cellpadding="0"
                  cellspacing="0"
                  width="100%"
                  style="margin: 0 0 40px 0"
                >
                  <tr>
                    <td align="center">
                      <a
                        href="<%= verifyLink %>"
                        target="_blank"
                        style="
                          display: inline-block;
                          padding: 16px 40px;
                          background-color: #007aff;
                          color: #ffffff;
                          font-size: 17px;
                          font-weight: 500;
                          text-decoration: none;
                          border-radius: 12px;
                          line-height: 1;
                          min-width: 180px;
                          text-align: center;
                          box-shadow: 0 2px 8px rgba(0, 122, 255, 0.28);
                        "
                      >
                        Verify Email
                      </a>
                    </td>
                  </tr>
                </table>

                <p
                  style="
                    margin: 0;
                    font-size: 15px;
                    color: #6e6e73;
                    line-height: 1.47;
                    text-align: center;
                  "
                >
                  If you didn’t create an account, you can safely ignore this
                  email.
                </p>
              </td>
            </tr>

            <!-- Fallback link -->
            <tr>
              <td style="padding: 0 32px 48px 32px; text-align: center">
                <a
                  href="<%= verifyLink %>"
                  target="_blank"
                  style="
                    color: #007aff;
                    font-size: 15px;
                    text-decoration: underline;
                    opacity: 0.9;
                  "
                >
                  Or copy and paste this link in your browser:
                </a>
                <div
                  style="
                    margin-top: 12px;
                    font-size: 13px;
                    color: #8e8e93;
                    word-break: break-all;
                    line-height: 1.4;
                  "
                >
                  <%= verifyLink %>
                </div>
              </td>
            </tr>
          </table>

          <!-- Footer -->
          <table
            role="presentation"
            border="0"
            cellpadding="0"
            cellspacing="0"
            width="100%"
            style="max-width: 480px; margin-top: 32px"
          >
            <tr>
              <td style="text-align: center; padding: 0 20px">
                <p
                  style="
                    margin: 0;
                    font-size: 13px;
                    color: #8e8e93;
                    line-height: 1.5;
                  "
                >
                  © <%= year %> YourApp Inc.<br />
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
